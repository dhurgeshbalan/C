#include <stdio.h>
#include <stdlib.h>
int main() {
   int n;
   scanf("%d", &n);
   int len = 2 * n - 1; // Calculate the size of the square matrix
   for (int i = 0; i < len; i++) {
       for (int j = 0; j < len; j++) {
           // Determine the minimum distance to the edges
           int min = i < j ? i : j;
           min = min < len - i - 1 ? min : len - i - 1;
           min = min < len - j - 1 ? min : len - j - 1;
           // Print the value based on the distance
           printf("%d ", n - min);
       }
       printf("\n"); // Move to the next row
   }
   return 0;
}
